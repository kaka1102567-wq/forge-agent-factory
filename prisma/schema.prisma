generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// === Enums ===

enum DomainStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

enum AgentStatus {
  DRAFT
  TESTING
  ACTIVE
  DEPLOYED
  DISABLED
}

enum DeployChannel {
  TELEGRAM
  WEB
}

enum DeploymentStatus {
  ACTIVE
  ROLLED_BACK
  STOPPED
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// === Models ===

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  image        String?
  role         Role     @default(VIEWER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts     Account[]
  activityLogs ActivityLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Domain {
  id        String       @id @default(cuid())
  name      String
  industry  String
  function  String       // Chức năng chính: sales, support, marketing...
  channels  String[]     // Kênh triển khai: web, zalo, messenger...
  tone      String       // Giọng điệu: formal, friendly, professional...
  profile   Json         // Thông tin mở rộng về domain
  status    DomainStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  documents Document[]
  agents    Agent[]

  @@map("domains")
}

model Template {
  id        String   @id @default(cuid())
  name      String
  category  String   // Phân loại: greeting, faq, objection-handling...
  type      String   // Loại: system-prompt, response, workflow...
  content   String   @db.Text
  variables Json     // Các biến có thể thay thế trong template
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  @@unique([name])
  @@map("templates")
}

model Document {
  id           String         @id @default(cuid())
  domainId     String
  templateId   String?
  title        String
  content      String         @db.Text
  qualityScore  Float?         // Điểm chất lượng từ AI scoring (0-100)
  qualityDetail Json?          // Chi tiết chấm điểm: relevance, completeness, clarity, tone, suggestions
  status        DocumentStatus @default(DRAFT)
  version       Int            @default(1)
  versionHistory Json          @default("[]") // Array of {version, content, savedAt}, max 10
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  domain   Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("documents")
}

model Agent {
  id           String      @id @default(cuid())
  domainId     String
  name         String
  archetype    String      // Kiểu agent: sales, support, onboarding...
  systemPrompt String      @db.Text
  config       Json        // Cấu hình mở rộng: temperature, max_tokens...
  quickMode    Boolean     @default(false) // Tạo từ Quick Mode
  status       AgentStatus @default(DRAFT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  domain       Domain        @relation(fields: [domainId], references: [id], onDelete: Cascade)
  testCases    TestCase[]
  testResults  TestResult[]
  deployments  Deployment[]
  costLogs     CostLog[]
  activityLogs ActivityLog[]

  @@map("agents")
}

model TestCase {
  id             String   @id @default(cuid())
  agentId        String
  round          Int      // Vòng test: 1-6
  category       String   @default("general") // Phân loại: functional, edge_case, safety...
  input          String   @db.Text
  expectedOutput String   @db.Text
  actualOutput   String?  @db.Text
  score          Float?   // Điểm đánh giá (0-100)
  passed         Boolean? // Kết quả pass/fail
  reasoning      String?  @db.Text // Lý do đánh giá từ AI judge
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

model TestResult {
  id        String   @id @default(cuid())
  agentId   String
  round     Int      // Vòng test tương ứng
  score     Float    // Điểm tổng (0-100)
  passed    Boolean
  details   Json     // Chi tiết kết quả: metrics, failures...
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("test_results")
}

model Deployment {
  id                   String           @id @default(cuid())
  agentId              String
  channel              DeployChannel
  status               DeploymentStatus @default(ACTIVE)
  config               Json             @default("{}")  // Channel config: botToken, webhookSecret...
  systemPromptSnapshot String           @db.Text         // Snapshot tại thời điểm deploy
  healthStatus         HealthStatus     @default(UNKNOWN)
  lastHealthCheck      DateTime?
  healthDetails        Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, channel])
  @@map("deployments")
}

model CostLog {
  id           String   @id @default(cuid())
  agentId      String?
  model        String   // haiku, sonnet, opus
  task         String   // TaskType: classify, generate, assemble...
  inputTokens  Int
  outputTokens Int
  cost         Float    // USD
  createdAt    DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([agentId])
  @@map("cost_logs")
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String   // deploy, test_run, quality_score, status_change...
  agentId     String?
  userId      String?
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([agentId])
  @@index([userId])
  @@map("activity_logs")
}
